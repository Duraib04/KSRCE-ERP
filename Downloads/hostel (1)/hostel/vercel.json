{
  "version": 2,
  "buildCommand": "cd frontend && npm run build",
  "framework": "vite",
  "outputDirectory": "frontend/dist",
  "installCommand": "npm install && cd backend && npm install && cd ../frontend && npm install",
  "devCommand": "npm run dev",
  "env": {
    "VITE_API_URL": "@vite_api_url"
  },
  "functions": {
    "api/**": {
      "runtime": "nodejs18.x"
    }
  }
}
